# VPS .env şablonu — sunucuda proje kökünde ".env" olarak kaydet.
# Gerçek değerleri Vercel'den çekebilirsin:
#   vercel env pull deploy/.env.vps.real --environment=production
# sonra sunucuya kopyala:
#   scp deploy/.env.vps.real root@104.247.164.217:/home/anlasmalievlilik.com/app/.env

# ---- Veritabanı (Neon — DEĞİŞMİYOR) ----
DATABASE_URL="postgresql://...neon...?sslmode=require"
DIRECT_URL="postgresql://...neon-direct...?sslmode=require"

# ---- NextAuth / Auth.js ----
# AUTH_SECRET: Vercel'dekiyle AYNI değeri kullan (farklı olursa herkes çıkış yapar)
AUTH_SECRET="..."
NEXTAUTH_SECRET="..."
AUTH_TRUST_HOST="true"
# VPS'te kendi domainin (reverse proxy + SSL ile):
AUTH_URL="https://anlasmalievlilik.net"
NEXTAUTH_URL="https://anlasmalievlilik.net"

# ---- SEO: canonical/sitemap/OG için yayın domaini ----
NEXT_PUBLIC_SITE_URL="https://anlasmalievlilik.net"

# ---- Görseller ----
# VPS'te görseller LOKAL diskte (public/uploads/) tutulur — Cloudinary GEREKMEZ.
# Aşağıdaki satırı SİL ya da boş bırak; saveImage() otomatik yerel sürücüye düşer.
# IMAGE_DRIVER="cloudinary"
# CLOUDINARY_CLOUD_NAME="..."
# CLOUDINARY_API_KEY="..."
# CLOUDINARY_API_SECRET="..."

# ---- Brevo (e-posta — DEĞİŞMİYOR) ----
BREVO_API_KEY="..."
EMAIL_FROM="AnlaşmalıEvlilik <noreply@anlasmalievlilik.net>"

# ---- Cron temizlik endpoint koruması ----
# crontab'daki Bearer değeriyle AYNI olmalı
CRON_SECRET="..."

# ---- Sentry (hata izleme) ----
# Sentry'de proje oluştur → DSN'i buraya koy. Boşsa Sentry devre dışıdır.
NEXT_PUBLIC_SENTRY_DSN="https://...@oXXXX.ingest.sentry.io/XXXX"
# Aşağıdakiler yalnız build sırasında kaynak haritası yüklemek için (opsiyonel):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

NODE_ENV="production"
